#!/usr/local/cpanel/3rdparty/bin/perl
#
# UserTools — AdminBin
# Executado como root pelo adminbind daemon.
#
# O método get_caller_username() é garantido pelo cPanel — retorna o
# usuário autenticado que originou a chamada. É IMPOSSÍVEL um usuário
# passar outro nome aqui, o que torna seguro agir sobre $user sem
# parâmetros externos.

package Cpanel::Admin::Modules::Cpanel::usertools;

use strict;
use warnings;

use POSIX ();

use parent 'Cpanel::Admin::Base';

use constant _actions => qw(
    KILL_PROCS
    FIX_PERMS
);

sub KILL_PROCS {
    my ($self) = @_;
    my $user = _assert_user( $self->get_caller_username() );

    # Conta processos antes do kill (informativo)
    my $before = qx{/usr/bin/pgrep -c -u \Q$user\E 2>/dev/null};
    chomp $before if defined $before;
    $before = '0' unless defined $before && length $before;

    # Dispara o kill em um filho destacado. O cPanel LiveAPI que fez
    # esta chamada roda como o próprio usuário — se mandarmos pkill
    # agora, o parent morre antes de devolver o JSON pro browser.
    # Um detour via fork+sleep garante que a resposta chegue antes.
    my $pid = fork();
    die "Falha no fork: $!\n" if !defined $pid;

    if ( $pid == 0 ) {
        # Filho (também root, não afetado pelo pkill -u $user)
        close STDIN;
        close STDOUT;
        close STDERR;
        open STDOUT, '>', '/dev/null';
        open STDERR, '>', '/dev/null';

        POSIX::setsid();

        sleep 3;

        exec( '/usr/bin/pkill', '-9', '-u', $user );
        exit 0;    # fallback se exec falhar
    }

    return {
        success => \1,
        message => "Finalização iniciada ($before processos detectados). "
            . "Sua sessão pode cair por alguns segundos — recarregue a página se isso acontecer.",
    };
}

sub FIX_PERMS {
    my ($self) = @_;
    my $user = _assert_user( $self->get_caller_username() );

    # 1. Script oficial do cPanel — cobre /home/user, public_html,
    #    mail/, .ssh/, etc/, cgi-bin/, SUID/SGID indevidos, CageFS.
    qx{/scripts/fixhomedirperms \Q$user\E 2>&1};
    my $exit = $? >> 8;

    # 2. Complemento — addon/subdomínios com docroot FORA de
    #    /home/user/public_html não são normalizados pelo script oficial.
    #    Lemos /var/cpanel/userdata/user/* e aplicamos chown/chmod padrão.
    my $extra = _fix_extra_docroots($user);

    my $msg;
    if ( $exit == 0 ) {
        $msg = "Owner e permissões corrigidos em /home/$user.";
        $msg .= " Docroots fora de public_html tratados: $extra." if $extra > 0;
    }
    else {
        $msg = "Falha no /scripts/fixhomedirperms (código $exit).";
    }

    return {
        success => $exit == 0 ? \1 : \0,
        message => $msg,
    };
}

# ---------------------------------------------------------------------------
# Descobre os documentroots do usuário que estão FORA de public_html e
# aplica: chown -R user:user, dirs 755, arquivos 644, .cgi/.pl 755,
# docroot em si 755. Retorna quantos docroots foram tratados.
#
# Os arquivos em /var/cpanel/userdata/<user>/* são YAML escritos pelo
# cPanel; para cada domínio/addon/subdomínio há um arquivo com a chave
# documentroot: <caminho>.
sub _fix_extra_docroots {
    my ($user) = @_;

    my @pw = getpwnam($user);
    return 0 unless @pw;
    my $home = $pw[7];
    return 0 unless defined $home && -d $home;

    my $public_html  = "$home/public_html";
    my $userdata_dir = "/var/cpanel/userdata/$user";
    return 0 unless -d $userdata_dir;

    opendir( my $dh, $userdata_dir ) or return 0;
    my @files;
    while ( my $entry = readdir $dh ) {
        next if $entry =~ /^\./;
        next if $entry =~ /\.cache$/;
        next if $entry =~ /_SSL$/;
        next if $entry eq 'main';
        my $path = "$userdata_dir/$entry";
        push @files, $path if -f $path;
    }
    closedir $dh;

    my ( %seen, @docroots );
    for my $file (@files) {
        open( my $fh, '<', $file ) or next;
        while ( my $line = <$fh> ) {
            next unless $line =~ /^\s*documentroot\s*:\s*(.+?)\s*$/;
            my $dr = $1;
            $dr =~ s/^["']|["']$//g;

            # Só nos interessa docroot fora de public_html e dentro do home.
            next if $dr eq $public_html;
            next if $dr =~ m{^\Q$public_html\E/};
            next unless $dr =~ m{^\Q$home\E/};
            next if $seen{$dr}++;
            push @docroots, $dr if -d $dr;
        }
        close $fh;
    }

    my $count = 0;
    for my $dr (@docroots) {
        system( '/bin/chown', '-R', "$user:$user", $dr );
        system( '/usr/bin/find', $dr, '-type', 'd',
            '-exec', '/bin/chmod', '755', '{}', '+' );
        system( '/usr/bin/find', $dr, '-type', 'f',
            '-exec', '/bin/chmod', '644', '{}', '+' );
        system( '/usr/bin/find', $dr, '-type', 'f',
            '(', '-name', '*.cgi', '-o', '-name', '*.pl', ')',
            '-exec', '/bin/chmod', '755', '{}', '+' );
        system( '/bin/chmod', '755', $dr );
        $count++;
    }

    return $count;
}

# ---------------------------------------------------------------------------
# Validação de nome de usuário.
# Mesmo vindo do cPanel (fonte confiável), fazemos untaint explícito.
sub _assert_user {
    my ($user) = @_;
    if ( !defined $user || $user !~ /^([a-z0-9_\-]{1,32})$/ ) {
        die "Usuário inválido\n";
    }
    return $1;
}

__PACKAGE__->new->run() unless caller;

1;
