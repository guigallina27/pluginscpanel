#!/usr/local/cpanel/3rdparty/bin/perl
#
# UserTools — AdminBin
# Executado como root pelo adminbind daemon.
#
# O método get_caller_username() é garantido pelo cPanel — retorna o
# usuário autenticado que originou a chamada. É IMPOSSÍVEL um usuário
# passar outro nome aqui, o que torna seguro agir sobre $user sem
# parâmetros externos.

package Cpanel::Admin::Modules::Cpanel::usertools;

use strict;
use warnings;

use POSIX ();

use parent 'Cpanel::Admin::Base';

use constant _actions => qw(
    KILL_PROCS
    FIX_PERMS
);

sub KILL_PROCS {
    my ($self) = @_;
    my $user = _assert_user( $self->get_caller_username() );

    # Conta processos antes do kill (informativo)
    my $before = qx{/usr/bin/pgrep -c -u \Q$user\E 2>/dev/null};
    chomp $before if defined $before;
    $before = '0' unless defined $before && length $before;

    # Dispara o kill em um filho destacado. O cPanel LiveAPI que fez
    # esta chamada roda como o próprio usuário — se mandarmos pkill
    # agora, o parent morre antes de devolver o JSON pro browser.
    # Um detour via fork+sleep garante que a resposta chegue antes.
    my $pid = fork();
    die "Falha no fork: $!\n" if !defined $pid;

    if ( $pid == 0 ) {
        # Filho (também root, não afetado pelo pkill -u $user)
        close STDIN;
        close STDOUT;
        close STDERR;
        open STDOUT, '>', '/dev/null';
        open STDERR, '>', '/dev/null';

        POSIX::setsid();

        sleep 3;

        exec( '/usr/bin/pkill', '-9', '-u', $user );
        exit 0;    # fallback se exec falhar
    }

    return {
        success => \1,
        message => "Finalização iniciada ($before processos detectados). "
            . "Sua sessão pode cair por alguns segundos — recarregue a página se isso sub FIX_PERMS {
    my ($self) = @_;
    my $user = _assert_user( $self->get_caller_username() );

    my @pw = getpwnam($user);
    if (!@pw) {
        return { success => \0, message => "Usuário não encontrado." };
    }
    my $home = $pw[7];
    if (!defined $home || !-d $home || $home eq '/' || $home eq '/root') {
        return { success => \0, message => "Home directory inválido." };
    }

    # 1. Obter grupo nobody para setar permissão na raiz do public_html
    my $nobody_gid;
    my @nb_pw = getgrnam('nobody');
    $nobody_gid = $nb_pw[2] if @nb_pw;
    my $user_uid = $pw[2];
    my $user_gid = $pw[3];

    # 2. Ajuste superficial recursivo no diretório $home nativo (ignora symlinks internos)
    system('/bin/chmod', '711', $home);
    system('/bin/chown', "$user:$user", $home);

    # 3. Descobrir recursivamente todas as pastas documentroot (public_html e addondomains)
    my @docroots;
    my $public_html = "$home/public_html";
    push @docroots, $public_html if -d $public_html;

    my $userdata_dir = "/var/cpanel/userdata/$user";
    if (-d $userdata_dir) {
        opendir(my $dh, $userdata_dir);
        if ($dh) {
            my @files;
            while (my $entry = readdir $dh) {
                next if $entry =~ /^\./ || $entry =~ /\.cache$/ || $entry =~ /_SSL$/ || $entry eq 'main';
                push @files, "$userdata_dir/$entry" if -f "$userdata_dir/$entry";
            }
            closedir $dh;

            my %seen;
            $seen{$public_html} = 1;
            for my $file (@files) {
                open(my $fh, '<', $file) or next;
                while (my $line = <$fh>) {
                    next unless $line =~ /^\s*documentroot\s*:\s*(.+?)\s*$/;
                    my $dr = $1;
                    $dr =~ s/^["']|["']$//g;
                    # Apenas caminhos estritos dentro do $home
                    next unless $dr =~ m{^\Q$home\E/};
                    next if $seen{$dr}++;
                    push @docroots, $dr if -d $dr;
                }
                close $fh;
            }
        }
    }

    # 4. Ajustar restritamente os diretórios e public_html files
    my $count = 0;
    for my $dr (@docroots) {
        # Todo escopo de arquivos dos docroots ganha group user e owner user
        system('/bin/chown', '-R', "$user:$user", $dr);
        
        # Corrige dirs para 755 e arquivos para 644
        system('/usr/bin/find', $dr, '-type', 'd', '-exec', '/bin/chmod', '755', '{}', '+');
        system('/usr/bin/find', $dr, '-type', 'f', '-exec', '/bin/chmod', '644', '{}', '+');
        
        # Re-ajusta CGI files comuns
        system('/usr/bin/find', $dr, '-type', 'f', '(', '-name', '*.cgi', '-o', '-name', '*.pl', ')', '-exec', '/bin/chmod', '755', '{}', '+');
        
        if ($dr eq $public_html) {
            # Conf Padrão de Servidores EA4 pra public_html root container = (user:nobody 750)
            system('/bin/chmod', '750', $public_html);
            if (defined $nobody_gid) {
                chown($user_uid, $nobody_gid, $public_html);
            }
        } else {
            system('/bin/chmod', '755', $dr);
        }
        $count++;
    }

    return {
        success => \1,
        message => "Sucesso. Owner e permissões corrigidos na sua conta ($count docroots normalizados).",
    };
}

# Mesmo vindo do cPanel (fonte confiável), fazemos untaint explícito.
sub _assert_user {
    my ($user) = @_;
    if ( !defined $user || $user !~ /^([a-z0-9_\-]{1,32})$/ ) {
        die "Usuário inválido\n";
    }
    return $1;
}

__PACKAGE__->new->run() unless caller;

1;
