[%-
    # Template master do WHM (Jupiter) — injeta sidebar, header, breadcrumbs
    # e assets padrão em volta do conteúdo do plugin.
    USE Whostmgr;
    SET wrapper_path  = 'master_templates/master.tmpl';
    SET wrapper_theme = 'bootstrap';
-%]
[% WRAPPER $wrapper_path
    header = 'Ferramentas do Usuário',
    theme  = wrapper_theme
-%]

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
.ut-scope {
  --ut-bg:         #FFFFFF;
  --ut-bg-alt:     #F8FAFC;
  --ut-bg-hover:   #F1F5F9;
  --ut-text:       #0F172A;
  --ut-text-dim:   #475569;
  --ut-text-mute:  #94A3B8;
  --ut-border:     #E2E8F0;
  --ut-border-str: #CBD5E1;
  --ut-accent:     #2563EB;
  --ut-accent-dim: #DBEAFE;
  --ut-accent-dk:  #1D4ED8;
  --ut-danger:     #DC2626;
  --ut-danger-dim: #FEE2E2;
  --ut-danger-dk:  #B91C1C;
  --ut-warn:       #D97706;
  --ut-warn-dim:   #FEF3C7;
  --ut-success:    #16A34A;
  --ut-success-dim:#DCFCE7;
  --ut-shadow:     0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 3px rgba(15, 23, 42, 0.06);
  --ut-shadow-lg:  0 4px 6px -1px rgba(15, 23, 42, 0.08), 0 10px 15px -3px rgba(15, 23, 42, 0.1);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  color: var(--ut-text);
  font-size: 14px;
  line-height: 1.5;
  padding: 24px 16px;
  max-width: 860px;
  margin: 0 auto;
}
@media (prefers-color-scheme: dark) {
  .ut-scope {
    --ut-bg:         #1E293B;
    --ut-bg-alt:     #0F172A;
    --ut-bg-hover:   #334155;
    --ut-text:       #F1F5F9;
    --ut-text-dim:   #CBD5E1;
    --ut-text-mute:  #64748B;
    --ut-border:     #334155;
    --ut-border-str: #475569;
    --ut-accent-dim: rgba(37, 99, 235, 0.2);
    --ut-danger-dim: rgba(220, 38, 38, 0.2);
    --ut-warn-dim:   rgba(217, 119, 6, 0.2);
    --ut-success-dim:rgba(22, 163, 74, 0.2);
    --ut-shadow:     0 1px 2px rgba(0, 0, 0, 0.2), 0 1px 3px rgba(0, 0, 0, 0.3);
    --ut-shadow-lg:  0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 10px 15px -3px rgba(0, 0, 0, 0.5);
  }
}
.ut-scope, .ut-scope * { box-sizing: border-box; }

.ut-card {
  background: var(--ut-bg);
  border: 1px solid var(--ut-border);
  border-radius: 14px;
  box-shadow: var(--ut-shadow);
  overflow: hidden;
}
.ut-card-head {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 20px 24px;
  border-bottom: 1px solid var(--ut-border);
}
.ut-card-head-icon {
  width: 44px; height: 44px;
  border-radius: 10px;
  background: var(--ut-accent-dim);
  color: var(--ut-accent);
  font-size: 22px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ut-card-head-text { flex: 1; min-width: 0; }
.ut-card-title {
  margin: 0;
  font-size: 17px;
  font-weight: 600;
  letter-spacing: -0.01em;
}
.ut-card-subtitle {
  margin: 2px 0 0;
  color: var(--ut-text-dim);
  font-size: 13px;
}
.ut-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  background: var(--ut-accent-dim);
  color: var(--ut-accent);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  flex-shrink: 0;
}

.ut-card-body { padding: 24px; }

.ut-alert {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 14px;
  background: var(--ut-warn-dim);
  border-radius: 10px;
  font-size: 13px;
  color: var(--ut-text);
  margin-bottom: 20px;
}
.ut-alert i {
  color: var(--ut-warn);
  font-size: 16px;
  flex-shrink: 0;
  margin-top: 1px;
}
.ut-alert strong { color: var(--ut-text); font-weight: 600; }

.ut-field { margin-bottom: 20px; }
.ut-field-label {
  display: block;
  margin-bottom: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--ut-text-dim);
}

/* Combobox */
.ut-combo { position: relative; }
.ut-combo-input {
  position: relative;
  display: flex;
  align-items: center;
}
.ut-combo-input i.bi-search {
  position: absolute;
  left: 12px;
  color: var(--ut-text-mute);
  font-size: 15px;
  pointer-events: none;
}
.ut-input {
  width: 100%;
  padding: 10px 36px 10px 36px;
  background: var(--ut-bg-alt);
  border: 1px solid var(--ut-border);
  border-radius: 10px;
  color: var(--ut-text);
  font-size: 14px;
  font-family: inherit;
  transition: all 0.15s;
}
.ut-input::placeholder { color: var(--ut-text-mute); }
.ut-input:focus {
  outline: none;
  border-color: var(--ut-accent);
  background: var(--ut-bg);
  box-shadow: 0 0 0 3px var(--ut-accent-dim);
}
.ut-combo-clear {
  position: absolute;
  right: 8px;
  width: 24px; height: 24px;
  border: none;
  background: transparent;
  color: var(--ut-text-mute);
  cursor: pointer;
  border-radius: 6px;
  display: none;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}
.ut-combo-clear:hover { background: var(--ut-bg-hover); color: var(--ut-text); }
.ut-combo.has-value .ut-combo-clear { display: flex; }
.ut-list {
  position: absolute;
  top: calc(100% + 4px);
  left: 0; right: 0;
  background: var(--ut-bg);
  border: 1px solid var(--ut-border);
  border-radius: 10px;
  box-shadow: var(--ut-shadow-lg);
  max-height: 280px;
  overflow-y: auto;
  z-index: 20;
  list-style: none;
  margin: 0;
  padding: 4px;
}
.ut-list[hidden] { display: none; }
.ut-list-item {
  padding: 9px 12px;
  border-radius: 6px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
  transition: background 0.1s;
}
.ut-list-item:hover,
.ut-list-item.ut-focused { background: var(--ut-bg-hover); }
.ut-list-item-user {
  font-weight: 600;
  color: var(--ut-text);
  font-size: 13px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ut-list-item-domain {
  color: var(--ut-text-mute);
  font-size: 12px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: right;
}
.ut-list-empty {
  padding: 20px;
  text-align: center;
  color: var(--ut-text-mute);
  font-size: 13px;
}

/* Selected pill */
.ut-selected {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: var(--ut-accent-dim);
  border: 1px solid transparent;
  border-radius: 10px;
  color: var(--ut-text);
}
.ut-selected[hidden] { display: none; }
.ut-selected i.bi-check-circle-fill {
  color: var(--ut-accent);
  font-size: 18px;
  flex-shrink: 0;
}
.ut-selected-info { flex: 1; min-width: 0; }
.ut-selected-user { font-weight: 600; }
.ut-selected-domain { color: var(--ut-text-dim); font-size: 12px; }
.ut-btn-link {
  background: none;
  border: none;
  color: var(--ut-accent);
  font-weight: 600;
  cursor: pointer;
  font-size: 13px;
  padding: 4px 8px;
  border-radius: 6px;
}
.ut-btn-link:hover { background: rgba(37, 99, 235, 0.1); }

/* Action buttons */
.ut-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
@media (max-width: 600px) {
  .ut-actions { grid-template-columns: 1fr; }
}
.ut-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 11px 18px;
  border: 1px solid transparent;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.15s;
}
.ut-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}
.ut-btn i { font-size: 16px; }

.ut-btn-primary {
  background: var(--ut-accent);
  color: #fff;
}
.ut-btn-primary:hover:not(:disabled) { background: var(--ut-accent-dk); }
.ut-btn-danger {
  background: var(--ut-bg);
  color: var(--ut-danger);
  border-color: var(--ut-border-str);
}
.ut-btn-danger:hover:not(:disabled) {
  background: var(--ut-danger);
  color: #fff;
  border-color: var(--ut-danger);
}

/* Result */
.ut-result {
  margin-top: 20px;
  padding: 12px 14px;
  border-radius: 10px;
  font-size: 13px;
  display: none;
  align-items: flex-start;
  gap: 10px;
  word-break: break-word;
}
.ut-result.show { display: flex; }
.ut-result i { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.ut-result.success { background: var(--ut-success-dim); color: var(--ut-text); }
.ut-result.success i { color: var(--ut-success); }
.ut-result.error { background: var(--ut-danger-dim); color: var(--ut-text); }
.ut-result.error i { color: var(--ut-danger); }

.ut-spinner {
  display: inline-block;
  width: 14px; height: 14px;
  border: 2px solid currentColor;
  border-right-color: transparent;
  border-radius: 50%;
  animation: ut-spin 0.6s linear infinite;
}
@keyframes ut-spin { to { transform: rotate(360deg); } }
</style>

<div class="ut-scope">
  <div class="ut-card">
    <header class="ut-card-head">
      <div class="ut-card-head-icon"><i class="bi bi-tools" aria-hidden="true"></i></div>
      <div class="ut-card-head-text">
        <h2 class="ut-card-title">Ferramentas do Usuário</h2>
        <p class="ut-card-subtitle">Ações de manutenção em contas cPanel</p>
      </div>
      <span class="ut-badge">[% data.role_label | html %]</span>
    </header>

    <div class="ut-card-body">
      <div class="ut-alert" role="note">
        <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
        <div>
          <strong>Atenção:</strong> finalizar processos interrompe PHP-FPM, cron, SSH
          e aplicações do usuário. Corrigir permissões reescreve owner/grupo e modos
          do diretório home.
        </div>
      </div>

      <div class="ut-field">
        <label class="ut-field-label" for="ut-search">Conta cPanel</label>

        <div id="ut-combo" class="ut-combo">
          <div class="ut-combo-input">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input
              id="ut-search"
              class="ut-input"
              type="text"
              placeholder="Carregando contas..."
              autocomplete="off"
              spellcheck="false"
              disabled
              aria-label="Buscar conta cPanel"
              aria-autocomplete="list"
              aria-controls="ut-list"
            >
            <button id="ut-clear" class="ut-combo-clear" type="button" aria-label="Limpar busca" tabindex="-1">
              <i class="bi bi-x-lg" aria-hidden="true"></i>
            </button>
          </div>
          <ul id="ut-list" class="ut-list" role="listbox" hidden></ul>
        </div>

        <div id="ut-selected" class="ut-selected" style="margin-top:10px" hidden>
          <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
          <div class="ut-selected-info">
            <div class="ut-selected-user" id="ut-selected-user"></div>
            <div class="ut-selected-domain" id="ut-selected-domain"></div>
          </div>
          <button id="ut-change" type="button" class="ut-btn-link">Trocar</button>
        </div>
      </div>

      <div class="ut-actions">
        <button id="ut-btn-kill" type="button" class="ut-btn ut-btn-danger" disabled>
          <i class="bi bi-x-octagon" aria-hidden="true"></i>
          Finalizar Processos
        </button>
        <button id="ut-btn-fix" type="button" class="ut-btn ut-btn-primary" disabled>
          <i class="bi bi-wrench-adjustable" aria-hidden="true"></i>
          Corrigir Permissões &amp; Owner
        </button>
      </div>

      <div id="ut-result" class="ut-result" role="status" aria-live="polite"></div>
    </div>
  </div>
</div>

<script>
(function() {
  'use strict';

  // URL do browser inclui o cpsess token da sessão WHM.
  var URL_SELF = window.location.pathname;

  var combo      = document.getElementById('ut-combo');
  var input      = document.getElementById('ut-search');
  var list       = document.getElementById('ut-list');
  var clearBtn   = document.getElementById('ut-clear');
  var selected   = document.getElementById('ut-selected');
  var selUser    = document.getElementById('ut-selected-user');
  var selDomain  = document.getElementById('ut-selected-domain');
  var changeBtn  = document.getElementById('ut-change');
  var btnKill    = document.getElementById('ut-btn-kill');
  var btnFix     = document.getElementById('ut-btn-fix');
  var result     = document.getElementById('ut-result');

  var accounts   = [];   // [{user, domain}, ...]
  var filtered   = [];
  var focusedIdx = -1;
  var chosenUser = null;

  // ---- result helpers ----
  function showResult(ok, msg) {
    result.className = 'ut-result show ' + (ok ? 'success' : 'error');
    result.innerHTML = '';
    var i = document.createElement('i');
    i.className = 'bi ' + (ok ? 'bi-check-circle-fill' : 'bi-x-octagon-fill');
    result.appendChild(i);
    var s = document.createElement('span');
    s.textContent = msg;
    result.appendChild(s);
  }
  function clearResult() { result.className = 'ut-result'; result.innerHTML = ''; }

  function jsonFetch(url, init) {
    init = init || {};
    init.credentials = 'same-origin';
    init.headers = Object.assign({ 'Accept': 'application/json' }, init.headers || {});
    return fetch(url, init).then(function(r) {
      var ct = r.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        throw new Error('Resposta não-JSON (status ' + r.status + '). Confira /usr/local/cpanel/logs/error_log.');
      }
      return r.json();
    });
  }

  // ---- list render ----
  function renderList(items) {
    list.innerHTML = '';
    if (!items.length) {
      var empty = document.createElement('li');
      empty.className = 'ut-list-empty';
      empty.textContent = 'Nenhuma conta encontrada.';
      list.appendChild(empty);
      return;
    }
    items.forEach(function(u, i) {
      var li = document.createElement('li');
      li.className = 'ut-list-item';
      li.setAttribute('role', 'option');
      li.setAttribute('data-user', u.user);
      li.setAttribute('data-domain', u.domain || '');
      li.setAttribute('data-idx', i);

      var uEl = document.createElement('span');
      uEl.className = 'ut-list-item-user';
      uEl.textContent = u.user;
      var dEl = document.createElement('span');
      dEl.className = 'ut-list-item-domain';
      dEl.textContent = u.domain || '';

      li.appendChild(uEl);
      li.appendChild(dEl);
      li.addEventListener('mousedown', function(e) {
        e.preventDefault();
        pick(u);
      });
      li.addEventListener('mouseenter', function() {
        setFocused(i);
      });
      list.appendChild(li);
    });
  }

  function filter(q) {
    q = (q || '').trim().toLowerCase();
    if (!q) { filtered = accounts.slice(); }
    else {
      filtered = accounts.filter(function(u) {
        return u.user.toLowerCase().includes(q)
            || (u.domain || '').toLowerCase().includes(q);
      });
    }
    renderList(filtered);
    focusedIdx = filtered.length ? 0 : -1;
    setFocused(focusedIdx);
  }

  function setFocused(i) {
    focusedIdx = i;
    Array.from(list.children).forEach(function(el, idx) {
      el.classList.toggle('ut-focused', idx === i);
    });
    if (i >= 0) {
      var el = list.children[i];
      if (el && el.scrollIntoView) el.scrollIntoView({ block: 'nearest' });
    }
  }

  function openList() {
    if (!accounts.length) return;
    filter(input.value);
    list.hidden = false;
  }
  function closeList() { list.hidden = true; }

  function pick(u) {
    chosenUser = u.user;
    selUser.textContent = u.user;
    selDomain.textContent = u.domain || '(sem domínio principal)';
    selected.hidden = false;
    combo.style.display = 'none';
    btnKill.disabled = false;
    btnFix.disabled  = false;
    clearResult();
    closeList();
  }

  function unpick() {
    chosenUser = null;
    selected.hidden = true;
    combo.style.display = '';
    btnKill.disabled = true;
    btnFix.disabled  = true;
    input.value = '';
    combo.classList.remove('has-value');
    clearResult();
    setTimeout(function() { input.focus(); }, 0);
  }

  // ---- event wiring ----
  input.addEventListener('focus', openList);
  input.addEventListener('click', openList);
  input.addEventListener('input', function() {
    combo.classList.toggle('has-value', !!input.value);
    filter(input.value);
    list.hidden = false;
  });
  input.addEventListener('keydown', function(e) {
    if (list.hidden && (e.key === 'ArrowDown' || e.key === 'Enter')) {
      openList();
      e.preventDefault();
      return;
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (focusedIdx < filtered.length - 1) setFocused(focusedIdx + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (focusedIdx > 0) setFocused(focusedIdx - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (focusedIdx >= 0 && filtered[focusedIdx]) pick(filtered[focusedIdx]);
    } else if (e.key === 'Escape') {
      closeList();
    }
  });
  clearBtn.addEventListener('click', function() {
    input.value = '';
    combo.classList.remove('has-value');
    filter('');
    input.focus();
  });
  changeBtn.addEventListener('click', unpick);
  document.addEventListener('click', function(e) {
    if (!combo.contains(e.target)) closeList();
  });

  // ---- actions ----
  function runAction(act, btn, confirmMsg) {
    if (!chosenUser) return;
    if (!confirm(confirmMsg)) return;

    var originalHTML = btn.innerHTML;
    btnKill.disabled = true; btnFix.disabled = true;
    btn.innerHTML = '<span class="ut-spinner"></span> Executando...';
    clearResult();

    var form = new FormData();
    form.append('action', act);
    form.append('user', chosenUser);

    jsonFetch(URL_SELF, { method: 'POST', body: form }).then(function(d) {
      showResult(!!d.success, d.message || (d.success ? 'Concluído.' : 'Falhou.'));
    }).catch(function(e) {
      showResult(false, e.message || String(e));
    }).then(function() {
      btn.innerHTML = originalHTML;
      btnKill.disabled = false; btnFix.disabled = false;
    });
  }

  btnKill.addEventListener('click', function() {
    runAction(
      'kill_procs', btnKill,
      'Finalizar TODOS os processos de "' + chosenUser + '"?\n\n' +
      'Isso mata sites, cron, SSH e qualquer processo do usuário.'
    );
  });
  btnFix.addEventListener('click', function() {
    runAction(
      'fix_perms', btnFix,
      'Corrigir owner e permissões do /home/' + chosenUser + '?\n\n' +
      'Isso pode levar alguns segundos em contas grandes.'
    );
  });

  // ---- initial load ----
  jsonFetch(URL_SELF + '?action=list_users').then(function(d) {
    if (!d.success) {
      input.placeholder = 'Erro ao carregar contas';
      showResult(false, d.message || 'Falha ao listar usuários.');
      return;
    }
    accounts = d.users || [];
    input.disabled = false;
    input.placeholder = accounts.length
      ? 'Buscar por usuário ou domínio...'
      : 'Nenhuma conta disponível';
    filtered = accounts.slice();
  }).catch(function(e) {
    input.placeholder = 'Erro ao carregar contas';
    showResult(false, e.message || String(e));
  });
})();
</script>

[% END %]
